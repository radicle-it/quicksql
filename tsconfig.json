{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "./dist-types",
    "outDir": "./dist-ts"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/quick-erd"]
}
